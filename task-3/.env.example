# AI Challenge 2.0 · Task 3 — environment template
#
# Copy this file to `.env` next to docker-compose.yml and fill the values.
# `.env` is gitignored — never commit secrets.

# === Postgres (n8n metadata + project tables) ===
POSTGRES_USER=n8n
POSTGRES_PASSWORD=replace-me-with-strong-random-string
POSTGRES_DB=n8n

# === n8n core ===
# Encryption key for credentials at rest. Generate once:
#   openssl rand -hex 32
N8N_ENCRYPTION_KEY=replace-me-with-openssl-rand-hex-32

# Public HTTPS host of n8n (ngrok reserved hostname, no protocol).
# Telegram requires HTTPS for webhooks; localhost will NOT work.
N8N_HOST=your-reserved.ngrok.dev
N8N_WEBHOOK_URL=https://your-reserved.ngrok.dev

# === Telegram ===
# Token from @BotFather: send /newbot, follow prompts, copy the token.
TELEGRAM_BOT_TOKEN=000000000:AA-replace-me-with-real-token

# === Anthropic ===
# Existing personal API key (Opus 4.7 for Teacher, Haiku 4.5 for Examiner).
ANTHROPIC_API_KEY=sk-ant-api03-replace-me

# === ngrok ===
# Sign in to ngrok dashboard → Your Authtoken → copy.
NGROK_AUTHTOKEN=replace-me-with-ngrok-authtoken
# Reserved subdomain (book one for free at https://dashboard.ngrok.com/domains).
# Bare hostname, no protocol, no path. Example: seniorprepcoach.ngrok.dev
NGROK_DOMAIN=your-reserved.ngrok.dev

# === Timezone ===
TZ=Asia/Tashkent
